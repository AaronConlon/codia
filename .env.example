# [Variable] Codia 运行端口，容器内部固定使用 3000。
# 示例：3000
PORT=3000

# [Variable] 宿主机暴露端口，Docker Compose 会映射到容器 3000。
# 示例：3000
CODIA_HOST_PORT=3000

# [Variable] SQLite 数据库文件路径。容器中默认写入持久化 volume。
# 示例：/app/data/codia.sqlite
CODIA_DB_PATH=/app/data/codia.sqlite

# [Variable] 宿主机上的 SQLite 持久化目录。OVO 部署时默认挂载在部署目录下。
# 示例：/opt/codia/data
CODIA_DATA_ROOT=/opt/codia/data

# [Variable] 当前部署版本号，由 CI 从 Git tag 注入。
# 示例：v1.0.0
APP_VERSION=

# [Variable] 当前 OVO 发布版本号，必须和 meta.json.release_tag 一致。
# 示例：v1.0.0
OVO_RELEASE_VERSION=

# [Variable] 当前发布 commit sha，由 CI 注入。
# 示例：8ee113d4b1b53b2d1c0a6e3f3b5773f923278e8b
OVO_RELEASE_COMMIT=

# [Variable] OVO server 地址。
# 示例：https://ovo.i5lin.top
OVO_DEPLOY_URL=https://ovo.i5lin.top

# [Secret] OVO deploy token，用于 GitHub Actions 安装 ovo-ci 并发布 bundle。
# 示例：ovo_deploy_xxx
OVO_DEPLOY_TOKEN=

# [Variable] OVO 目标 client id。
# 示例：3
OVO_TARGET_CLIENT_ID=3

# [Variable] OVO 目标 service id。
# 示例：9
OVO_TARGET_SERVICE_ID=9

# [Variable] 目标机器上的部署目录，OVO client 执行 deploy.sh 时会把 bundle 同步到这里。
# 示例：/opt/codia
OVO_DEPLOY_TARGET_ROOT=/opt/codia

# [Variable] Docker Compose 使用的外部 network 名称。
# 示例：web
OVO_DOCKER_NETWORK=web

# [Variable] Docker Compose project 名称。
# 示例：codia
OVO_COMPOSE_PROJECT_NAME=codia

# [Variable] Codia 容器名称。
# 示例：codia
OVO_CONTAINER_NAME=codia

# [Variable] OVO 健康检查地址，会写入 meta.json.ovo_env.OVO_HEALTHCHECK_URL。
# 示例：https://codia.example.com/api/health
OVO_HEALTHCHECK_URL=http://127.0.0.1:3000/api/health

# [Variable] 健康检查超时时间，单位秒。
# 示例：60
OVO_HEALTHCHECK_TIMEOUT_SECONDS=60

# [Secret] bundle zip 密码。可选，留空时 CI 会自动生成十六进制随机值。
# 示例：0123456789abcdef0123456789abcdef
BUNDLE_ZIP_PASSWORD=
