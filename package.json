{
  "name": "codia",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "build:release": "bash scripts/build-release.sh",
    "sync:github-env": "bash scripts/sync-github-env.sh",
    "sync:github-production-env": "bash scripts/sync-github-env.sh --env-file .env.production --env production"
  },
  "dependencies": {
    "@fontsource/fira-code": "^5.2.7",
    "@hono/node-server": "^1.18.2",
    "@hono/swagger-ui": "^0.5.2",
    "@hono/zod-openapi": "^1.4.0",
    "hono": "^4.12.30",
    "shiki": "^3.13.0",
    "takumi-js": "^2.1.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "code-inspector-plugin": "^2.0.1",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
