{
  "name": "codia",
  "version": "0.1.41",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/write-build-info.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "db:init": "node dist/db/init.js",
    "prebuild": "node scripts/write-build-info.mjs",
    "build": "tsc",
    "pretypecheck": "node scripts/write-build-info.mjs",
    "typecheck": "tsc --noEmit",
    "build:release": "bash scripts/build-release.sh",
    "release": "standard-version",
    "release:patch": "standard-version --release-as patch",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:push": "git push --follow-tags origin HEAD",
    "sync:github-env": "bash scripts/sync-github-env.sh",
    "sync:github-production-env": "bash scripts/sync-github-env.sh --env-file .env.production --env production"
  },
  "dependencies": {
    "@fontsource/fira-code": "^5.2.7",
    "@hono/node-server": "^1.18.2",
    "@hono/swagger-ui": "^0.5.2",
    "@hono/zod-openapi": "^1.4.0",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "shiki": "^3.13.0",
    "takumi-js": "^2.1.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "code-inspector-plugin": "^2.0.1",
    "standard-version": "^9.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
